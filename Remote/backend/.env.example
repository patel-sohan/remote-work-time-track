# Server Configuration
PORT=5001
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/productivity_tracker

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRE=7d

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# CORS Configuration
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Screenshot Configuration
SCREENSHOT_RETENTION_DAYS=30
SCREENSHOT_MAX_SIZE=5242880

# Email Configuration (Multi-Provider Support)
# Choose ONE provider and configure its credentials

# Gmail Configuration
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_16_character_app_password

# Outlook Configuration (Alternative to Gmail)
# OUTLOOK_USER=your_email@outlook.com
# OUTLOOK_PASS=your_outlook_password

# Yahoo Configuration (Alternative to Gmail/Outlook)
# YAHOO_USER=your_email@yahoo.com
# YAHOO_PASS=your_yahoo_app_password

# Test Email Configuration (Fallback - No setup required)
# If no provider is configured above, test emails will be used
# Test emails can be viewed at: https://ethereal.email
